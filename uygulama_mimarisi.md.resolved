    MW --> LV["LedgerView (💰)"]

    IV -->|fatura kaydet| db[("db singleton")]
    IV -->|stok azalt| db
    IV -->|bakiye güncelle| db
    IV -->|ledger yaz| db

    SV -->|ExcelHelper| EH["excel_helper.py"]
    CV -->|ExcelHelper| EH

    SQV -->|PDF rapor| PH["pdf_helper.py"]
    IV -->|Yazdır| PRH["print_helper.py"]

    db --> INV["inventory.json"]
    db --> CON["contacts.json"]
    db --> LED["ledger.json"]
    db --> INV2["invoices.json"]
```

